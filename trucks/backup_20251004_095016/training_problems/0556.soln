(load package1 truck1 a1 l2)
(load package2 truck2 a2 l2)
(drive truck1 l2 l4 t0 t1)
(load package3 truck2 a1 l2)
(unload package1 truck1 a1 l4)
(deliver package1 l4 t1 t5)
(drive truck2 l2 l3 t1 t2)
(unload package3 truck2 a1 l3)
(deliver package3 l3 t2 t2)
(unload package2 truck2 a2 l3)
(deliver package2 l3 t2 t5)
